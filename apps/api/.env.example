# Environment
NODE_ENV=development
PORT=3000
ENVIRONMENT=staging

# Database (Cloud SQL via Auth Proxy or direct for local dev)
DATABASE_URL="postgresql://fatedworld_api:password@localhost:5432/fatedworld?schema=public"

# Redis (Cloud Memorystore or local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT - use RS256 in prod (generated key pair); HS256 acceptable for local dev
JWT_ACCESS_SECRET=change-me-in-production-use-rsa
JWT_REFRESH_SECRET=change-me-in-production-use-rsa
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# GCP Project
GCP_PROJECT_ID=fatedworld-staging
GCP_REGION=us-central1

# Cloud SQL (used by Cloud SQL Auth Proxy in Cloud Run)
CLOUD_SQL_CONNECTION_NAME=fatedworld-staging:us-central1:fatedworld-staging

# GCS Buckets
GCS_UPLOAD_BUCKET=fatedworld-upload-staging
GCS_DELIVERY_BUCKET=fatedworld-delivery-staging
GCS_THUMBNAILS_BUCKET=fatedworld-thumbnails-staging
GCS_DISTRIBUTION_BUCKET=fatedworld-distribution-staging

# Cloud CDN
CDN_BASE_URL=https://cdn.fatedworld.com
CDN_SIGNING_KEY=
CDN_SIGNING_KEY_NAME=fatedworld-key

# Cloud Tasks
CLOUD_TASKS_EPISODE_PUBLISH_QUEUE=episode-publish-staging
CLOUD_TASKS_NOTIFICATION_QUEUE=notification-queue-staging
CLOUD_TASKS_DISTRIBUTION_QUEUE=distribution-export-staging
CLOUD_TASKS_API_BASE_URL=https://api-url.a.run.app

# Pub/Sub Topics
PUBSUB_ANALYTICS_TOPIC=analytics-events-staging
PUBSUB_EPISODE_PUBLISHED_TOPIC=episode-published-staging
PUBSUB_IAP_REFUND_TOPIC=iap-refund-staging
PUBSUB_DISTRIBUTION_JOBS_TOPIC=distribution-jobs-staging

# Apple IAP
APPLE_APP_BUNDLE_ID=com.fatedworld.app

# Google IAP
GOOGLE_PLAY_PACKAGE_NAME=com.fatedworld.app

# Anthropic (distribution copy generation)
ANTHROPIC_API_KEY=

# FCM (Firebase Cloud Messaging)
FIREBASE_PROJECT_ID=fatedworld-staging

# Internal endpoints (Cloud Run service URL for task callbacks)
INTERNAL_API_URL=http://localhost:3000
